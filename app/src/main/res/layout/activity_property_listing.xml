<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1565C0"
            android:padding="20dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:id="@+id/tvWelcome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Logged in as: admin"
                android:textSize="12sp"
                android:textColor="#90CAF9"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="New Property Listing"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fill in the details below"
                android:textSize="13sp"
                android:textColor="#BBDEFB" />

        </LinearLayout>

        <!-- Form Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Property Address -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Property Address"
                    android:textSize="13sp"
                    android:textColor="#424242"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/etAddress"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="e.g. 123 Mango St., Cebu City"
                    android:inputType="textPostalAddress"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:background="@drawable/rounded_edittext"
                    android:textColor="#212121"
                    android:textColorHint="#BDBDBD"
                    android:textSize="14sp"
                    android:layout_marginBottom="16dp" />

                <!-- Price -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Price (₱)"
                    android:textSize="13sp"
                    android:textColor="#424242"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/etPrice"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="e.g. 3500000"
                    android:inputType="numberDecimal"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:background="@drawable/rounded_edittext"
                    android:textColor="#212121"
                    android:textColorHint="#BDBDBD"
                    android:textSize="14sp"
                    android:layout_marginBottom="16dp" />

                <!-- Type -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Property Type"
                    android:textSize="13sp"
                    android:textColor="#424242"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/etType"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="e.g. Condo, House and Lot, Townhouse"
                    android:inputType="text"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:background="@drawable/rounded_edittext"
                    android:textColor="#212121"
                    android:textColorHint="#BDBDBD"
                    android:textSize="14sp"
                    android:layout_marginBottom="16dp" />

                <!-- Square Footage -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Square Footage (sq ft)"
                    android:textSize="13sp"
                    android:textColor="#424242"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/etSquareFootage"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="e.g. 120"
                    android:inputType="numberDecimal"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:background="@drawable/rounded_edittext"
                    android:textColor="#212121"
                    android:textColorHint="#BDBDBD"
                    android:textSize="14sp"
                    android:layout_marginBottom="16dp" />

                <!-- Number of Bedrooms -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Number of Bedrooms"
                    android:textSize="13sp"
                    android:textColor="#424242"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/etBedrooms"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="e.g. 3"
                    android:inputType="number"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:background="@drawable/rounded_edittext"
                    android:textColor="#212121"
                    android:textColorHint="#BDBDBD"
                    android:textSize="14sp"
                    android:layout_marginBottom="24dp" />

                <!-- Save Button -->
                <Button
                    android:id="@+id/btnSave"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="SAVE &amp; CONTINUE"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#1565C0"
                    android:stateListAnimator="@null" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
