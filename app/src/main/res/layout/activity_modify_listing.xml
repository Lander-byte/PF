<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#0D47A1"
            android:padding="20dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LISTING DETAILS"
                android:textSize="11sp"
                android:textColor="#90CAF9"
                android:letterSpacing="0.1"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Property Summary"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Read-only view of your listing"
                android:textSize="13sp"
                android:textColor="#BBDEFB" />

        </LinearLayout>

        <!-- Read-only notice banner -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFF3E0"
            android:padding="12dp"
            android:layout_marginBottom="16dp"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@android:drawable/ic_dialog_info"
                android:tint="#E65100"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="All fields are read-only. Go back to edit."
                android:textSize="13sp"
                android:textColor="#E65100" />

        </LinearLayout>

        <!-- Details Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Property Address -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Property Address"
                    android:textSize="11sp"
                    android:textColor="#1565C0"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/etAddressDetail"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:focusable="false"
                    android:clickable="false"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:background="@drawable/rounded_edittext_readonly"
                    android:textColor="#424242"
                    android:textSize="14sp"
                    android:layout_marginBottom="16dp" />

                <!-- Price -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Price"
                    android:textSize="11sp"
                    android:textColor="#1565C0"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/etPriceDetail"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:focusable="false"
                    android:clickable="false"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:background="@drawable/rounded_edittext_readonly"
                    android:textColor="#424242"
                    android:textSize="14sp"
                    android:layout_marginBottom="16dp" />

                <!-- Type -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Property Type"
                    android:textSize="11sp"
                    android:textColor="#1565C0"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/etTypeDetail"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:focusable="false"
                    android:clickable="false"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:background="@drawable/rounded_edittext_readonly"
                    android:textColor="#424242"
                    android:textSize="14sp"
                    android:layout_marginBottom="16dp" />

                <!-- Square Footage -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Square Footage"
                    android:textSize="11sp"
                    android:textColor="#1565C0"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/etSqftDetail"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:focusable="false"
                    android:clickable="false"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:background="@drawable/rounded_edittext_readonly"
                    android:textColor="#424242"
                    android:textSize="14sp"
                    android:layout_marginBottom="16dp" />

                <!-- Number of Bedrooms -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Number of Bedrooms"
                    android:textSize="11sp"
                    android:textColor="#1565C0"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/etBedroomsDetail"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:focusable="false"
                    android:clickable="false"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:background="@drawable/rounded_edittext_readonly"
                    android:textColor="#424242"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Action Buttons -->
        <Button
            android:id="@+id/btnBack"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="← BACK TO LISTING"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#1565C0"
            android:backgroundTint="#FFFFFF"
            android:strokeColor="#1565C0"
            android:strokeWidth="2dp"
            android:stateListAnimator="@null"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="LOGOUT"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#C62828"
            android:stateListAnimator="@null"
            android:layout_marginBottom="20dp" />

    </LinearLayout>
</ScrollView>
